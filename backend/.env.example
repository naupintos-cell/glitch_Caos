# ─── MercadoPago ──────────────────────────────────────────────────────────────
# Conseguís estas en https://www.mercadopago.com.ar/developers/panel/app
# Usá las de TEST primero, después las de PROD cuando estés listo

MP_ACCESS_TOKEN=TEST-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
MP_PUBLIC_KEY=TEST-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# ─── URLs ─────────────────────────────────────────────────────────────────────
# URL donde está hosteado el juego (sin barra al final)
FRONTEND_URL=https://tu-juego.netlify.app

# URL de este backend en Railway (sin barra al final)
# Railway te la da al hacer deploy: https://glitch-backend-xxxx.up.railway.app
BACKEND_URL=https://glitch-backend-xxxx.up.railway.app

# Orígenes permitidos para CORS (separados por coma si hay más de uno)
ALLOWED_ORIGINS=https://tu-juego.netlify.app

# ─── General ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
